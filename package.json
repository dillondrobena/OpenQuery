{
  "name": "openquery",
  "version": "0.1.0",
  "description": "Evidence explorer for databases — an agent-agnostic skill + local CLI that safely queries Postgres and renders answers as interactive entity graphs with SQL receipts. Your credentials never enter the AI's context.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openquery": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "viewer/",
    "demo/",
    "schema/",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "ajv": "^8.17.0",
    "commander": "^13.0.0",
    "force-graph": "^1.49.0",
    "pg": "^8.13.0",
    "pg-connection-string": "^2.14.0",
    "pg-cursor": "^2.12.0",
    "pgsql-parser": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
